# Protect your wrapper API. Requests must include: X-API-Key: your-long-random-key
APP_API_KEY=change-me-long-random-key

# Copy these from a logged-in gemini.google.com browser session.
GEMINI_SECURE_1PSID=replace-with-__Secure-1PSID
GEMINI_SECURE_1PSIDTS=replace-with-__Secure-1PSIDTS

# Optional
MAX_CONCURRENT_REQUESTS=2
GEMINI_REQUEST_TIMEOUT=300
GEMINI_INIT_TIMEOUT=30
GEMINI_AUTO_CLOSE_DELAY=300
GEMINI_VERBOSE=false
# OPENAI_COMPAT_DEFAULT_MODEL=gemini-web
# OPENAI_COMPAT_MODELS=gemini-web,gemini-3-flash-thinking-advanced
# HTTPS_PROXY=http://user:pass@host:port
# GEMINI_ACCOUNT_INDEX=0

# Protect your wrapper API.
# AI SDK will send this as: Authorization: Bearer <APP_API_KEY>
# curl/custom clients can also use: X-API-Key: <APP_API_KEY>
APP_API_KEY=change-me-long-random-key

# Copy these from a logged-in gemini.google.com browser session.
GEMINI_SECURE_1PSID=replace-with-__Secure-1PSID
GEMINI_SECURE_1PSIDTS=replace-with-__Secure-1PSIDTS

# Optional public OpenAI-compatible model id returned by /v1/models.
# In AI SDK you can call: geminiWeb('gemini-web')
OPENAI_COMPAT_MODEL=gemini-web

# Optional internal gemini_webapi model id to forward. Leave empty unless you know the repo's supported model values.
# GEMINI_WEB_MODEL=
# FORWARD_OPENAI_MODEL_TO_GEMINI=false

# Optional runtime limits
MAX_CONCURRENT_REQUESTS=2
GEMINI_REQUEST_TIMEOUT=300
GEMINI_INIT_TIMEOUT=30
GEMINI_AUTO_CLOSE_DELAY=300
GEMINI_VERBOSE=false
# HTTPS_PROXY=http://user:pass@host:port
# GEMINI_ACCOUNT_INDEX=0
